#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="${0##*/}"
readonly CADDYFILE_PATH="/etc/caddy/Caddyfile"
readonly CADDY_CONFIG_DIR="/etc/caddy/conf.d"

usage() {
    cat <<EOF
Usage:
  ${SCRIPT_NAME} setup [project] [app-path] [php-fpm-socket]
  ${SCRIPT_NAME} revert [project]
  ${SCRIPT_NAME} proxy <name> <port> [upstream-host]
  ${SCRIPT_NAME} unproxy <name>
  ${SCRIPT_NAME} status [project]
  ${SCRIPT_NAME} status-proxy <name>
  ${SCRIPT_NAME} self-test

Defaults:
  project: sacredcube
  app-path: current directory
  php-fpm-socket: /run/php-fpm/php-fpm.sock
EOF
}

die() {
    echo "${SCRIPT_NAME}: $*" >&2
    exit 1
}

is_valid_name() {
    [[ "${1}" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]
}

is_valid_port() {
    [[ "${1}" =~ ^[0-9]+$ && ${#1} -le 5 ]] &&
        ((10#${1} >= 1 && 10#${1} <= 65535))
}

is_valid_host() {
    [[ "${1}" =~ ^[[:alnum:]_.-]+$ || "${1}" =~ ^\[[0-9A-Fa-f:]+\]$ ]]
}

validate_name() {
    is_valid_name "${1}" || die "invalid name '${1}'; use lowercase letters, digits, and hyphens"
}

require_root() {
    ((EUID == 0)) && return
    command -v sudo >/dev/null || die "this action requires root and sudo is not installed"
    exec sudo -- "$(readlink -f "$0")" "$@"
}

require_command() {
    command -v "${1}" >/dev/null || die "${1} is not installed"
}

quote_caddy_value() {
    local value="${1//\\/\\\\}"
    printf '"%s"' "${value//\"/\\\"}"
}

ensure_config_import() {
    grep -Eq '^[[:space:]]*import[[:space:]]+/etc/caddy/conf\.d/\*[[:space:]]*$' \
        "${CADDYFILE_PATH}" && return
    printf '\n# Local development sites\nimport /etc/caddy/conf.d/*\n' >>"${CADDYFILE_PATH}"
}

validate_caddy_config() {
    require_command runuser
    runuser -u caddy -- env XDG_DATA_HOME=/var/lib XDG_CONFIG_HOME=/etc \
        caddy validate "$@"
}

# Install or remove a site config, rolling back if the full Caddyfile becomes invalid.
apply_config_change() {
    local config_path="${1}"
    local replacement_path="${2:-}"
    local backup_path=""

    if [[ -f "${config_path}" ]]; then
        backup_path="$(mktemp)"
        cp "${config_path}" "${backup_path}"
    fi

    if [[ -n "${replacement_path}" ]]; then
        install -m 644 "${replacement_path}" "${config_path}"
    else
        rm -f "${config_path}"
    fi

    if validate_caddy_config --config "${CADDYFILE_PATH}"; then
        [[ -z "${backup_path}" ]] || rm -f "${backup_path}"
        return
    fi

    if [[ -n "${backup_path}" ]]; then
        install -m 644 "${backup_path}" "${config_path}"
    else
        rm -f "${config_path}"
    fi
    [[ -z "${backup_path}" ]] || rm -f "${backup_path}"
    return 1
}

write_caddy_config() {
    local config_path="${1}"
    local candidate_path

    candidate_path="$(mktemp)"
    cat >"${candidate_path}"
    chmod 644 "${candidate_path}"
    if ! validate_caddy_config --adapter caddyfile --config "${candidate_path}" ||
        ! apply_config_change "${config_path}" "${candidate_path}"; then
        rm -f "${candidate_path}"
        die "Caddy rejected ${config_path}; the previous config was restored"
    fi
    rm -f "${candidate_path}"
}

remove_caddy_config() {
    apply_config_change "${1}" || die "Caddy rejected the removal; the config was restored"
}

activate_caddy() {
    local active_action="${1:-reload}"

    systemctl enable caddy >/dev/null
    if systemctl is-active --quiet caddy; then
        systemctl "${active_action}" caddy
    else
        systemctl start caddy
    fi
}

ensure_caddy_socket_access() {
    local socket_path="${1}"
    local socket_group

    require_command runuser
    if runuser -u caddy -- test -w "${socket_path}"; then
        return
    fi

    socket_group="$(stat -c %G "${socket_path}")"
    getent group "${socket_group}" >/dev/null || die "PHP-FPM socket has no valid group"
    # Group membership persists because the socket is shared by every Caddy site.
    if ! id -nG caddy | tr ' ' '\n' | grep -Fxq "${socket_group}"; then
        require_command usermod
        usermod --append --groups "${socket_group}" caddy
    fi

    runuser -u caddy -- test -w "${socket_path}" ||
        die "the caddy user cannot connect to ${socket_path}"
}

grant_path_traversal() {
    local user="${1}"
    local path="${2}"

    while [[ "${path}" != / ]]; do
        setfacl -m "u:${user}:--x" "${path}"
        path="${path%/*}"
        [[ -n "${path}" ]] || path=/
    done
}

grant_laravel_access() {
    local app_root="${1}"
    local socket_path="${2}"
    local fpm_user
    local runtime_dir

    require_command setfacl
    fpm_user="$(stat -c %U "${socket_path}")"
    id "${fpm_user}" >/dev/null || die "could not determine the PHP-FPM user"
    id caddy >/dev/null || die "the caddy user does not exist"

    ensure_caddy_socket_access "${socket_path}"
    grant_path_traversal caddy "${app_root}"
    grant_path_traversal "${fpm_user}" "${app_root}"
    setfacl -R -m u:caddy:rX "${app_root}/public"
    find "${app_root}/public" -type d -exec setfacl -m d:u:caddy:rx {} +

    for runtime_dir in "${app_root}/storage" "${app_root}/bootstrap/cache"; do
        [[ -d "${runtime_dir}" ]] || die "Laravel runtime directory not found: ${runtime_dir}"
        setfacl -R -m "u:${fpm_user}:rwX" "${runtime_dir}"
        find "${runtime_dir}" -type d -exec setfacl -m "d:u:${fpm_user}:rwx" {} +
    done
}

setup_site() {
    local project_name="${1}"
    local app_path="${2}"
    local socket_path="${3}"
    local app_root
    local public_dir
    local config_path="${CADDY_CONFIG_DIR}/${project_name}.conf"

    validate_name "${project_name}"
    [[ -d "${app_path}" ]] || die "project path not found: ${app_path}"
    app_root="$(readlink -f "${app_path}")"
    public_dir="${app_root}/public"
    [[ "${app_root}" != /home/* && "${app_root}" != /root/* && "${app_root}" != /run/user/* ]] ||
        die "Arch's caddy service cannot read projects under ${app_root}; use /srv or /mnt"
    [[ -d "${public_dir}" ]] || die "Laravel public directory not found: ${public_dir}"
    [[ -S "${socket_path}" ]] || die "PHP-FPM socket not found: ${socket_path}"

    grant_laravel_access "${app_root}" "${socket_path}"
    install -d "${CADDY_CONFIG_DIR}"
    ensure_config_import
    write_caddy_config "${config_path}" <<EOF
${project_name}.test, *.${project_name}.test {
    root * $(quote_caddy_value "${public_dir}")
    encode zstd gzip
    php_fastcgi $(quote_caddy_value "unix//${socket_path}")
    file_server
    tls internal
}
EOF
    # Restart once so a newly added PHP-FPM socket group takes effect.
    activate_caddy restart
    caddy trust --config "${CADDYFILE_PATH}"

    echo "Serving ${public_dir} at https://${project_name}.test and its subdomains."
}

remove_site() {
    local project_name="${1}"

    validate_name "${project_name}"
    remove_caddy_config "${CADDY_CONFIG_DIR}/${project_name}.conf"
    if systemctl is-active --quiet caddy; then
        systemctl reload caddy
    fi
    echo "Removed ${project_name}.test."
}

setup_proxy() {
    local proxy_name="${1}"
    local upstream_port="${2}"
    local upstream_host="${3}"
    local config_path="${CADDY_CONFIG_DIR}/${proxy_name}.proxy.conf"

    validate_name "${proxy_name}"
    is_valid_port "${upstream_port}" || die "invalid port '${upstream_port}'"
    is_valid_host "${upstream_host}" || die "invalid upstream host '${upstream_host}'"

    install -d "${CADDY_CONFIG_DIR}"
    ensure_config_import
    write_caddy_config "${config_path}" <<EOF
${proxy_name}.test {
    reverse_proxy $(quote_caddy_value "${upstream_host}:${upstream_port}")
    tls internal
}
EOF
    activate_caddy
    caddy trust --config "${CADDYFILE_PATH}"

    echo "Proxying https://${proxy_name}.test to ${upstream_host}:${upstream_port}."
}

remove_proxy() {
    local proxy_name="${1}"

    validate_name "${proxy_name}"
    remove_caddy_config "${CADDY_CONFIG_DIR}/${proxy_name}.proxy.conf"
    if systemctl is-active --quiet caddy; then
        systemctl reload caddy
    fi
    echo "Removed ${proxy_name}.test proxy."
}

show_status() {
    local site_name="${1}"
    local config_suffix="${2}"
    local config_path="${CADDY_CONFIG_DIR}/${site_name}${config_suffix}.conf"
    local caddy_state

    validate_name "${site_name}"
    caddy_state="$(systemctl is-active caddy 2>/dev/null || true)"
    echo "Caddy: ${caddy_state:-unknown}"
    caddy adapt --config "${CADDYFILE_PATH}" >/dev/null || true
    echo
    if [[ -f "${config_path}" ]]; then
        sed -n '1,120p' "${config_path}"
    else
        echo "Missing: ${config_path}"
    fi
    echo
    curl -kIsS --max-time 5 "https://${site_name}.test" | head -n 1 || true
}

self_test() {
    is_valid_name sacredcube
    is_valid_name local-dev
    ! is_valid_name 'Bad Name'
    is_valid_port 1
    is_valid_port 65535
    ! is_valid_port 0
    ! is_valid_port 65536
    ! is_valid_port 99999999999999999999
    is_valid_host localhost
    is_valid_host 127.0.0.1
    is_valid_host '[::1]'
    ! is_valid_host 'localhost { abort }'
    [[ "$(quote_caddy_value 'a path')" == '"a path"' ]]
    [[ "$(quote_caddy_value 'a"b')" == '"a\"b"' ]]
    echo "${SCRIPT_NAME}: self-test passed"
}

action="${1:-}"
case "${action}" in
    setup)
        require_root "$@"
        require_command caddy
        setup_site "${2:-sacredcube}" "${3:-${PWD}}" \
            "${4:-/run/php-fpm/php-fpm.sock}"
        ;;
    revert)
        require_root "$@"
        require_command caddy
        remove_site "${2:-sacredcube}"
        ;;
    proxy)
        [[ -n "${2:-}" && -n "${3:-}" ]] || die "proxy requires a name and port"
        require_root "$@"
        require_command caddy
        setup_proxy "${2}" "${3}" "${4:-127.0.0.1}"
        ;;
    unproxy)
        [[ -n "${2:-}" ]] || die "unproxy requires a name"
        require_root "$@"
        require_command caddy
        remove_proxy "${2}"
        ;;
    status)
        require_command caddy
        show_status "${2:-sacredcube}" ""
        ;;
    status-proxy)
        [[ -n "${2:-}" ]] || die "status-proxy requires a name"
        require_command caddy
        show_status "${2}" ".proxy"
        ;;
    self-test)
        self_test
        ;;
    *)
        usage
        [[ -z "${action}" ]] || exit 1
        ;;
esac
