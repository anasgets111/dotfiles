#!/usr/bin/env bash
set -euo pipefail

((EUID == 0)) || exec sudo -- "$0" "$@"

readonly green=$'\e[32m' magenta=$'\e[35m' cyan=$'\e[36m' bold=$'\e[1m' reset=$'\e[0m'

install_file() {
  local mode=$1 path=$2
  printf '  %b→%b %-50s ' "$magenta" "$reset" "$path"
  install -Dm "$mode" /dev/stdin "$path"
  printf '%b✓%b\n' "$green" "$reset"
}

printf '\n%b%b══════ Reboot Required Setup ══════%b\n\n' "$cyan" "$bold" "$reset"

install_file 755 /usr/local/bin/notify-reboot-required <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

components=("$@")
if ((${#components[@]} == 0)) && [[ ! -t 0 ]]; then
  mapfile -t components
fi

for i in "${!components[@]}"; do
  [[ ${components[i]} == usr/lib/modules/*/vmlinuz ]] && components[i]=kernel
done

if ((${#components[@]})); then
  title="System Restart Required"
  printf -v items ' • <code>%s</code><br/>' "${components[@]}"
  body="<b>The following components were updated:</b><br/>${items}<br/><i>A reboot is recommended to apply changes.</i>"
  console="Reboot required due to: ${components[*]}"
else
  title="Reboot Recommended"
  body="Core system components were updated. Please reboot at your convenience."
  console="Reboot is recommended after system updates."
fi

if [[ -t 2 ]]; then
  printf '\n\e[1;33m⚠\e[0m \e[1m%s\e[0m\n\n' "$console" >&2
else
  printf '==> %s\n' "$console" >&2
fi

while read -r _ user _; do
  busctl --machine="$user@.host" --user call \
    org.freedesktop.Notifications /org/freedesktop/Notifications \
    org.freedesktop.Notifications Notify susssasa{sv}i \
    "System Update" 0 system-reboot "$title" "$body" 0 \
    3 urgency y 2 \
    category s "device.software-update" \
    resident b true \
    0 &>/dev/null || true
done < <(loginctl list-users --no-legend)
SCRIPT

install_file 644 /etc/pacman.d/hooks/90-reboot-required.hook <<'HOOK'
[Trigger]
Operation = Upgrade
Type = Package
Target = amd-ucode
Target = intel-ucode
Target = linux-firmware
Target = nvidia
Target = nvidia-open
Target = nvidia-dkms
Target = nvidia-open-dkms
Target = nvidia-lts
Target = nvidia-open-lts

[Trigger]
Operation = Install
Operation = Upgrade
Type = Path
Target = usr/lib/modules/*/vmlinuz

[Action]
Description = Checking if reboot is required...
When = PostTransaction
NeedsTargets
Exec = /usr/local/bin/notify-reboot-required
HOOK

printf '\n  %b%b🎉 Success!%b Setup complete. Reboot notifications active.\n\n' \
  "$green" "$bold" "$reset"
