#!/bin/bash

# ponytail: This helper expects one live shell; add a selector if that changes.
set --
for qs_log in "$XDG_RUNTIME_DIR"/quickshell/by-pid/*/log.log; do
  qs_pid=${qs_log%/log.log}
  qs_pid=${qs_pid##*/}
  [[ -r $qs_log && -r /proc/$qs_pid/comm ]] || continue
  read -r qs_comm < "/proc/$qs_pid/comm"
  [[ $qs_comm == quickshell ]] && set -- "$@" "$qs_log"
done
[[ $# == 1 ]] || { echo "qs-log: expected one live Quickshell instance, found $#" >&2; exit 1; }

qs_instance=${1%/log.log}
sed_args=(-e 's/^[0-9]{4}-[0-9]{2}-[0-9]{2} ([0-9]{2}:[0-9]{2}:[0-9]{2})\.[0-9]+/[\1]/')
if [[ -t 1 && ! -v NO_COLOR ]]; then
  sed_args+=(
    -e 's/^(\[[0-9:]+\] +(DEBUG|INFO|WARN|ERROR|FATAL)( [^:]+)?: )(\[[^]]{16}\])/\1\x1b[35m\4\x1b[0m/'
    -e 's/^(\[[0-9:]+\])( DEBUG)( [^:]+)?:/\1\x1b[34m\2\x1b[97m\3\x1b[0m:/'
    -e 's/^(\[[0-9:]+\])(  INFO)( [^:]+)?:/\1\x1b[32m\2\x1b[97m\3\x1b[0m:/'
    -e 's/^(\[[0-9:]+\])(  WARN)( [^:]+)?:/\1\x1b[33m\2\x1b[97m\3\x1b[0m:/'
    -e 's/^(\[[0-9:]+\])( ERROR)( [^:]+)?:/\1\x1b[31m\2\x1b[97m\3\x1b[0m:/'
    -e 's/^(\[[0-9:]+\])( FATAL.*)$/\1\x1b[31m\2\x1b[0m/'
    -e 's/^(\[[0-9:]+\])/\x1b[36m\1\x1b[0m/'
  )
fi

tail --pid="${qs_instance##*/}" -n +1 -f "$1" | sed -u -E "${sed_args[@]}"
