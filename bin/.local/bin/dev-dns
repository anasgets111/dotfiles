#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="${0##*/}"
readonly NM_CONFIG_PATH="/etc/NetworkManager/conf.d/90-local-dev-dns.conf"
readonly DNSMASQ_CONFIG_PATH="/etc/NetworkManager/dnsmasq.d/90-local-dev.conf"

usage() {
    cat <<EOF
Usage:
  ${SCRIPT_NAME} setup [tld]
  ${SCRIPT_NAME} revert
  ${SCRIPT_NAME} status [tld]
  ${SCRIPT_NAME} self-test
EOF
}

die() {
    echo "${SCRIPT_NAME}: $*" >&2
    exit 1
}

is_valid_tld() {
    [[ "${1}" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]
}

validate_tld() {
    is_valid_tld "${1}" || die "invalid TLD '${1}'; use lowercase letters, digits, and hyphens"
}

require_root() {
    ((EUID == 0)) && return
    command -v sudo >/dev/null || die "this action requires root and sudo is not installed"
    exec sudo -- "$(readlink -f "$0")" "$@"
}

setup_dns() {
    local tld="${1#.}"

    validate_tld "${tld}"
    command -v dnsmasq >/dev/null || die "dnsmasq is not installed"

    if systemctl is-active --quiet dnsmasq; then
        die "the standalone dnsmasq service is active; disable it before using NetworkManager's dnsmasq plugin"
    fi

    install -d /etc/NetworkManager/conf.d /etc/NetworkManager/dnsmasq.d
    cat >"${NM_CONFIG_PATH}" <<'EOF'
[main]
dns=dnsmasq
EOF
    printf 'address=/.%s/127.0.0.1\n' "${tld}" >"${DNSMASQ_CONFIG_PATH}"

    dnsmasq --test --conf-file=/dev/null \
        --conf-dir=/etc/NetworkManager/dnsmasq.d >/dev/null
    systemctl restart NetworkManager

    for _ in {1..10}; do
        if getent ahostsv4 "anything.${tld}" | grep -q '^127\.0\.0\.1[[:space:]]'; then
            echo "*.${tld} now resolves to 127.0.0.1."
            return
        fi
        sleep 0.2
    done

    die "DNS setup completed, but anything.${tld} does not resolve to 127.0.0.1"
}

revert_dns() {
    rm -f "${NM_CONFIG_PATH}" "${DNSMASQ_CONFIG_PATH}"
    systemctl reload NetworkManager
    echo "Removed local development DNS."
}

show_status() {
    local tld="${1#.}"
    local nm_state

    validate_tld "${tld}"
    nm_state="$(systemctl is-active NetworkManager 2>/dev/null || true)"
    echo "NetworkManager: ${nm_state:-unknown}"
    echo "DNS mode:       $(grep -hs '^dns=' "${NM_CONFIG_PATH}" || echo default)"
    echo "Rule:           $(grep -hs '^address=' "${DNSMASQ_CONFIG_PATH}" || echo missing)"
    echo
    getent hosts "anything.${tld}" || true
}

self_test() {
    is_valid_tld test
    is_valid_tld local-dev
    ! is_valid_tld .test
    ! is_valid_tld 'test;option'
    echo "${SCRIPT_NAME}: self-test passed"
}

action="${1:-}"
case "${action}" in
    setup)
        require_root "$@"
        setup_dns "${2:-test}"
        ;;
    revert)
        require_root "$@"
        revert_dns
        ;;
    status)
        show_status "${2:-test}"
        ;;
    self-test)
        self_test
        ;;
    *)
        usage
        [[ -z "${action}" ]] || exit 1
        ;;
esac
